APP_NAME=Intelligent Campus Highlight Board API
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# MongoDB Atlas SRV (replace USER, PASSWORD, cluster host). Local: mongodb://127.0.0.1:27017
# Replace USER and PASSWORD with your Atlas database user (cluster host: campus.cinoqs3.mongodb.net).
# Local MongoDB: mongodb://127.0.0.1:27017
#
# If startup fails with DNS / SRV timeout (dnspython LifetimeTimeout): mongodb+srv requires DNS
# that can resolve _mongodb._tcp.<host>. Use Atlas "Connect" → standard connection string
# (mongodb://shard-00-00.xxx.mongodb.net:27017,...) OR use local MongoDB as above.
MONGODB_URI=mongodb+srv://USER:PASSWORD@campus.cinoqs3.mongodb.net/?appName=campus&retryWrites=true&w=majority
MONGODB_DB_NAME=campus_board
# If Atlas fails with SSL handshake / TLSV1_ALERT_INTERNAL_ERROR on Windows (e.g. Python 3.13), leave unset to use certifi.
# Last resort local dev only: MONGODB_TLS_INSECURE=true
# MONGODB_TLS_CA_FILE=C:\path\to\cacert.pem
MONGODB_TLS_INSECURE=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Local dev: fixes Flutter web / mixed origins when testing from browser
CORS_ALLOW_ALL=true
FIREBASE_CREDENTIALS_PATH=
